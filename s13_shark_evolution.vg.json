{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "§14 — How the picture of risk has changed: decade-by-decade species composition.",
  "background": null,
  "padding": {
    "left": 10,
    "right": 10,
    "top": 10,
    "bottom": 10
  },
  "config": {
    "view": {
      "stroke": null,
      "fill": null
    },
    "font": "Spectral",
    "axis": {
      "labelFont": "IBM Plex Mono",
      "labelFontSize": 10.5,
      "labelColor": "#3F4D5A",
      "titleFont": "IBM Plex Mono",
      "titleColor": "#3F4D5A",
      "titleFontSize": 10.5,
      "titleFontWeight": 600,
      "titlePadding": 10,
      "labelPadding": 5,
      "domainColor": "#14202C",
      "domainWidth": 1,
      "tickColor": "#B7AE99",
      "gridColor": "#14202C",
      "gridOpacity": 0.07
    },
    "legend": {
      "labelFont": "IBM Plex Mono",
      "labelFontSize": 10.5,
      "labelColor": "#3F4D5A",
      "titleFont": "IBM Plex Mono",
      "titleFontSize": 10,
      "titleColor": "#3F4D5A",
      "titleFontWeight": 600
    },
    "title": {
      "font": "IBM Plex Mono",
      "fontSize": 11,
      "fontWeight": 600,
      "color": "#14202C",
      "anchor": "start",
      "subtitleFont": "Spectral",
      "subtitleColor": "#3F4D5A"
    },
    "header": {
      "labelFont": "IBM Plex Mono",
      "labelColor": "#14202C",
      "titleFont": "IBM Plex Mono",
      "titleColor": "#3F4D5A"
    }
  },
  "spacing": 30,
  "resolve": {
    "scale": {
      "color": "independent"
    }
  },
  "vconcat": [
    {
      "title": {
        "text": "Total incidents per decade",
        "anchor": "start",
        "fontSize": 11,
        "font": "IBM Plex Mono",
        "color": "#5A6A78",
        "fontWeight": 500,
        "subtitle": "How the volume of recorded incidents has grown",
        "subtitleFontSize": 10,
        "subtitleFont": "IBM Plex Mono",
        "subtitleColor": "#A6B4C1",
        "offset": 10
      },
      "data": {
        "url": "data/asid_incidents.csv",
        "format": {
          "type": "csv"
        }
      },
      "width": 870,
      "height": 90,
      "mark": {
        "type": "bar",
        "color": "#16202A",
        "opacity": 0.78,
        "cornerRadiusEnd": 2,
        "stroke": "#FBFAF6",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "decade_label",
          "type": "ordinal",
          "axis": {
            "labelAngle": 0,
            "title": null,
            "labelPadding": 4,
            "ticks": false,
            "domain": false,
            "labelFontSize": 10
          },
          "sort": null
        },
        "y": {
          "field": "total",
          "type": "quantitative",
          "axis": {
            "title": null,
            "tickCount": 4,
            "grid": false,
            "domain": false,
            "ticks": false,
            "labelColor": "#A6B4C1"
          }
        },
        "tooltip": [
          {
            "field": "decade_label",
            "title": "Decade"
          },
          {
            "field": "total",
            "title": "Incidents"
          }
        ]
      },
      "transform": [
        {
          "filter": "datum.year != null && datum.year >= 1900"
        },
        {
          "calculate": "floor(toNumber(datum.year) / 10) * 10",
          "as": "decade"
        },
        {
          "calculate": "toString(datum.decade) + 's'",
          "as": "decade_label"
        },
        {
          "aggregate": [
            {
              "op": "count",
              "as": "total"
            }
          ],
          "groupby": [
            "decade",
            "decade_label"
          ]
        }
      ]
    },
    {
      "title": {
        "text": "Species attribution per decade",
        "anchor": "start",
        "fontSize": 11,
        "font": "IBM Plex Mono",
        "color": "#5A6A78",
        "fontWeight": 500,
        "subtitle": "How who-did-it has changed — early decades show heavy Tiger shark + 'Other' (poor identification); recent decades dominated by White sharks and better ID",
        "subtitleFontSize": 10,
        "subtitleFont": "IBM Plex Mono",
        "subtitleColor": "#A6B4C1",
        "offset": 10
      },
      "data": {
        "url": "data/asid_incidents.csv",
        "format": {
          "type": "csv"
        }
      },
      "transform": [
        {
          "filter": "datum.year != null && datum.year >= 1900"
        },
        {
          "calculate": "floor(toNumber(datum.year) / 10) * 10",
          "as": "decade"
        },
        {
          "calculate": "toString(datum.decade) + 's'",
          "as": "decade_label"
        },
        {
          "calculate": "indexof(['White shark','Bull shark','Tiger shark'], datum.species) >= 0 ? datum.species : 'Other'",
          "as": "species"
        },
        {
          "aggregate": [
            {
              "op": "count",
              "as": "count"
            }
          ],
          "groupby": [
            "decade",
            "decade_label",
            "species"
          ]
        },
        {
          "joinaggregate": [
            {
              "op": "sum",
              "field": "count",
              "as": "decade_total"
            }
          ],
          "groupby": [
            "decade"
          ]
        },
        {
          "calculate": "datum.count / datum.decade_total * 100",
          "as": "pct"
        }
      ],
      "facet": {
        "column": {
          "field": "decade_label",
          "type": "nominal",
          "header": {
            "title": null,
            "labelFontSize": 10.5,
            "labelFont": "IBM Plex Mono",
            "labelColor": "#16202A",
            "labelFontWeight": 500,
            "labelOrient": "bottom",
            "labelPadding": 6
          }
        }
      },
      "spacing": 4,
      "spec": {
        "width": 56,
        "height": 56,
        "view": {
          "stroke": null
        },
        "mark": {
          "type": "arc",
          "innerRadius": 14,
          "outerRadius": 26,
          "stroke": "#FBFAF6",
          "strokeWidth": 1
        },
        "encoding": {
          "theta": {
            "field": "count",
            "type": "quantitative",
            "stack": true
          },
          "color": {
            "field": "species",
            "type": "nominal",
            "scale": {
              "domain": [
                "White shark",
                "Bull shark",
                "Tiger shark",
                "Other"
              ],
              "range": [
                "#0072B2",
                "#D55E00",
                "#E6C200",
                "#7C8492"
              ]
            },
            "legend": null
          },
          "tooltip": [
            {
              "field": "decade_label",
              "title": "Decade"
            },
            {
              "field": "species",
              "title": "Species"
            },
            {
              "field": "count",
              "title": "Incidents"
            },
            {
              "field": "pct",
              "title": "Share",
              "format": ".0f"
            }
          ]
        }
      }
    }
  ]
}