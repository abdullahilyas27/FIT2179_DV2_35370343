          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFontSize": 10.5,
      "titleFontSize": 10,
      "titleFontWeight": 600,
      "labelFont": "IBM Plex Mono",
      "labelColor": "#5C6A75",
      "titleFont": "IBM Plex Mono",
      "titleColor": "#5C6A75"
    },
    "font": "Spectral",
    "axis": {
      "labelFont": "IBM Plex Mono",
      "labelFontSize": 10.5,
      "labelColor": "#5C6A75",
      "titleFont": "IBM Plex Mono",
      "titleFontSize": 10.5,
      "titleColor": "#5C6A75",
      "titleFontWeight": 600,
      "titlePadding": 10,
      "labelPadding": 5,
      "domainColor": "#14202C",
      "domainWidth": 1,
      "tickColor": "#B7AE99",
      "gridColor": "#14202C",
      "gridOpacity": 0.07
    },
    "title": {
      "font": "IBM Plex Mono",
      "fontSize": 11,
      "fontWeight": 600,
      "color": "#14202C",
      "anchor": "start",
      "subtitleFont": "Spectral",
      "subtitleColor": "#5C6A75"
    },
    "header": {
      "labelFont": "IBM Plex Mono",
      "labelColor": "#14202C",
      "titleFont": "IBM Plex Mono",
      "titleColor": "#5C6A75"
    }
  }
}