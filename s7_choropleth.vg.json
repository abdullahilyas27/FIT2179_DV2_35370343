            "lat": -35.6,
            "lon2": 152.0,
            "lat2": -34.0
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontFamily": "IBM Plex Mono",
        "fontWeight": 600,
        "fill": "#333333",
        "align": "left",
        "dx": 5
      },
      "encoding": {
        "longitude": {
          "field": "lon2",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat2",
          "type": "quantitative"
        },
        "text": {
