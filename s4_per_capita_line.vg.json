{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 820,
  "height": 420,
  "background": null,
  "config": {
    "font": "Spectral",
    "axis": {
      "labelFont": "IBM Plex Mono",
      "labelFontSize": 10.5,
      "labelColor": "#5C6A75",
      "titleFont": "IBM Plex Mono",
      "titleFontSize": 10.5,
      "titleColor": "#5C6A75",
      "domainColor": "#14202C",
      "tickColor": "#B7AE99",
      "gridColor": "#14202C",
      "gridOpacity": 0.07,
      "titleFontWeight": 600,
      "titlePadding": 10,
      "labelPadding": 5,
      "domainWidth": 1
    },
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFont": "IBM Plex Mono",
      "labelFontSize": 10.5,
      "labelColor": "#5C6A75",
      "titleFont": "IBM Plex Mono",
      "titleFontSize": 10,
      "titleColor": "#5C6A75",
      "titleFontWeight": 600
    },
    "title": {
      "font": "IBM Plex Mono",
      "fontSize": 11,
      "fontWeight": 600,
      "color": "#14202C",
      "anchor": "start",
      "subtitleFont": "Spectral",
      "subtitleColor": "#5C6A75"
    },
    "header": {
      "labelFont": "IBM Plex Mono",
      "labelColor": "#14202C",
      "titleFont": "IBM Plex Mono",
      "titleColor": "#5C6A75"
    }
  },
  "data": {
    "url": "data/asid_incidents.csv"
  },
  "transform": [
    {
      "aggregate": [
        {
          "op": "count",
          "as": "incidents"
        }
      ],
      "groupby": [
        "year"
      ]
    },
    {
      "calculate": "toString(datum.year)",
      "as": "year_str"
    },
    {
      "lookup": "year_str",
      "from": {
        "data": {
          "url": "data/abs_population.csv"
        },
        "key": "year",
        "fields": [
          "population"
        ]
      }
    },
    {
      "filter": "isValid(datum.population)"
    },
    {
      "calculate": "datum.incidents / (datum.population / 1000000)",
      "as": "incidents_per_million"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "interpolate": "monotone",
        "color": "#0B2D45",
        "opacity": 0.08
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "axis": {
            "title": "Year",
            "format": "d",
            "tickCount": 10
          }
        },
        "y": {
          "field": "incidents_per_million",
          "type": "quantitative",
          "axis": {
            "title": "Incidents per million people"
          }
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 3,
        "color": "#0B2D45"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative"
        },
        "y": {
          "field": "incidents_per_million",
          "type": "quantitative"
        }
      }
    },
    {
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ],
            "on": "pointerover",
            "clear": "pointerout",
            "nearest": true
          }
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 120,
        "color": "#0B2D45"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative"
        },
        "y": {
          "field": "incidents_per_million",
          "type": "quantitative"
        },
        "opacity": {
          "condition": {
            "param": "hover",
            "empty": false,
            "value": 1
          },
          "value": 0
        },
        "tooltip": [
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "incidents_per_million",
            "type": "quantitative",
            "title": "Per million",
            "format": ".3f"
          }
        ]
      }
    }
  ]
}